# --- API ---
PORT=3001
HOST=0.0.0.0
# Comma-separated list of allowed CORS origins for the web app
CORS_ORIGIN=http://localhost:5173

# Max upload size in bytes (default 25 MB)
MAX_UPLOAD_BYTES=26214400

# --- Auth / premium (provider-agnostic; wired later) ---
# One of: none | dev | stripe
AUTH_PROVIDER=dev
# Treat every request as premium (handy for local dev of premium features)
DEV_FORCE_PREMIUM=false

# --- Elevation provider (premium feature) ---
# One of: none | opentopodata | open-elevation
# Defaults to opentopodata (free, no key, rate-limited). Failed lookups fall
# back to linear interpolation. Use `none` to disable network calls.
ELEVATION_PROVIDER=opentopodata
ELEVATION_API_URL=
ELEVATION_API_KEY=

# --- Routing ("snap to path") ---
# One of: none | brouter. Defaults to BRouter (free, no key, trail-aware).
# Only called when the user opts in per gap; failures fall back to the straight
# route. Set `none` to disable, or point ROUTING_URL at your own BRouter server.
ROUTING_PROVIDER=brouter
ROUTING_URL=
ROUTING_PROFILE=trekking

# --- Web (dev) ---
# The browser always calls the API at the same origin under /api; in dev, Vite
# proxies /api to the API below. Override only if the API runs elsewhere.
# API_PROXY_TARGET=http://localhost:3001
